# Supabase Kronos (proyecto move-idworld)
SUPABASE_URL=https://zsmlntktqisiclzaxoky.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<tu_service_role_key>
SUPABASE_ANON_KEY=<tu_anon_key>

# Gemini API (compartido CAIA)
GEMINI_API_KEY=<tu_key>
GEMINI_MODEL_ORQUESTADOR=gemini-2.5-pro
GEMINI_MODEL_PERCEPCION=gemini-2.5-flash
GEMINI_MODEL_DECISION=gemini-2.5-flash

# Telegram bot BCBRP
TELEGRAM_BOT_TOKEN=<token>
TELEGRAM_CHAT_ID_BCBRP=<chat_id>

# WhatsApp Business
WHATSAPP_API_TOKEN=<token>
WHATSAPP_PHONE_ID=<phone_id>

# Edge inference
JETSON_DEVICE=cuda:0  # o cpu si dev
YOLO_WEIGHTS_PATH=./weights/yolov8n_fire.onnx
PFLASH_MODEL_PATH=./weights/pflash_svr.pkl

# Modo de operación
PIRO_ETAPA=0_pre  # 0_pre | 0_post | 1
PIRO_SHADOW_MODE=true
PIRO_LOG_LEVEL=INFO
